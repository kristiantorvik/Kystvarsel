{
  "expo": {
    "name": "Kystvarsel",
    "slug": "kystvarsel",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "kystvarsel",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E3A5F"
    },
    "platforms": [
      "android",
      "ios"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "no.kystvarsel.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "kystvarsel.alert-check"
        ]
      }
    },
    "android": {
      "package": "no.kystvarsel.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0E3A5F"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#0E3A5F"
        }
      ],
      [
        "expo-sqlite",
        {
          "useSQLCipher": false
        }
      ],
      "expo-background-task",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#0E3A5F"
        }
      ]
    ],
    "extra": {
      "metContactEmail": "kystvarsel.app@gmail.com",
      "appIdentifier": "kystvarsel"
    }
  }
}
